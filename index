<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NùN — memoria oceánica</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --desastre: #378ADD;
  --mitologia: #7F77DD;
  --geopolitica: #D85A30;
  --biologia: #1D9E75;
  --antropoceno: #BA7517;
  --bg: #050810;
  --texto: rgba(255,255,255,0.85);
}

body {
  background: var(--bg);
  color: var(--texto);
  font-family: 'Georgia', serif;
  overflow: hidden;
  width: 100vw;
  height: 100vh;
}

/* SUPERFICIE */
#superficie {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 100;
  background: var(--bg);
  transition: opacity 1.5s ease, visibility 1.5s ease;
}

#superficie.oculto {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

#titulo-nun {
  font-size: clamp(4rem, 12vw, 9rem);
  font-weight: 300;
  letter-spacing: 0.3em;
  color: white;
  margin-bottom: 0.5rem;
  opacity: 0;
  animation: aparecer 2s ease 0.5s forwards;
}

#subtitulo {
  font-size: clamp(0.8rem, 2vw, 1rem);
  letter-spacing: 0.4em;
  text-transform: lowercase;
  color: rgba(255,255,255,0.4);
  margin-bottom: 4rem;
  opacity: 0;
  animation: aparecer 2s ease 1.2s forwards;
}

#hundirse-btn {
  background: none;
  border: none;
  color: rgba(255,255,255,0.25);
  font-family: 'Georgia', serif;
  font-size: 0.75rem;
  letter-spacing: 0.5em;
  cursor: pointer;
  opacity: 0;
  animation: aparecer 2s ease 2.5s forwards;
  transition: color 0.8s ease;
  text-transform: lowercase;
}

#hundirse-btn:hover { color: rgba(255,255,255,0.6); }

#nav-superficie {
  position: fixed;
  top: 2rem;
  right: 2rem;
  display: flex;
  gap: 2rem;
  z-index: 110;
  opacity: 0;
  animation: aparecer 1s ease 3s forwards;
}

#nav-superficie a {
  color: rgba(255,255,255,0.25);
  text-decoration: none;
  font-size: 0.7rem;
  letter-spacing: 0.3em;
  text-transform: lowercase;
  transition: color 0.5s;
}

#nav-superficie a:hover { color: rgba(255,255,255,0.6); }

/* CAMPO PROFUNDO */
#campo {
  position: fixed;
  inset: 0;
  opacity: 0;
  visibility: hidden;
  transition: opacity 2s ease 0.5s, visibility 0s ease 2.5s;
}

#campo.visible {
  opacity: 1;
  visibility: visible;
  transition: opacity 2s ease 0.5s, visibility 0s ease 0s;
}

#canvas-campo {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

/* PANEL DE NODO */
#panel-nodo {
  position: fixed;
  inset: 0;
  display: grid;
  grid-template-columns: 1fr 340px;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.8s ease, visibility 0s ease 0.8s;
  z-index: 50;
  background: var(--bg);
}

#panel-nodo.visible {
  opacity: 1;
  visibility: visible;
  transition: opacity 0.8s ease, visibility 0s ease 0s;
}

#contenido-principal {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

#contenido-principal img {
  max-width: 100%;
  max-height: 100vh;
  object-fit: contain;
  opacity: 0;
  transition: opacity 1s ease;
}

#contenido-principal img.cargado { opacity: 1; }

#texto-nodo {
  position: absolute;
  bottom: 3rem;
  left: 3rem;
  right: 3rem;
  font-size: 0.85rem;
  line-height: 1.8;
  color: rgba(255,255,255,0.6);
  max-width: 60ch;
}

#nombre-nodo {
  position: absolute;
  top: 2.5rem;
  left: 3rem;
  font-size: clamp(1.5rem, 4vw, 3rem);
  font-weight: 300;
  letter-spacing: 0.15em;
  color: white;
}

/* FRANJA LATERAL */
#franja-lateral {
  border-left: 1px solid rgba(255,255,255,0.06);
  display: flex;
  flex-direction: column;
  padding: 2.5rem 2rem;
  overflow-y: auto;
  scrollbar-width: none;
}

#franja-lateral::-webkit-scrollbar { display: none; }

#label-conexiones {
  font-size: 0.6rem;
  letter-spacing: 0.4em;
  text-transform: lowercase;
  color: rgba(255,255,255,0.2);
  margin-bottom: 2rem;
}

.conexion-item {
  margin-bottom: 1.5rem;
  cursor: pointer;
  transition: opacity 0.3s;
  opacity: 0.5;
}

.conexion-item:hover { opacity: 1; }

.conexion-nombre {
  font-size: 0.85rem;
  letter-spacing: 0.1em;
  margin-bottom: 0.25rem;
}

.conexion-tipo {
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  text-transform: lowercase;
  opacity: 0.4;
}

.conexion-barra {
  height: 1px;
  margin-top: 0.5rem;
  background: currentColor;
  opacity: 0.3;
  transform-origin: left;
}

#btn-emerger {
  margin-top: auto;
  padding-top: 2rem;
  background: none;
  border: none;
  color: rgba(255,255,255,0.2);
  font-family: 'Georgia', serif;
  font-size: 0.65rem;
  letter-spacing: 0.5em;
  text-transform: lowercase;
  cursor: pointer;
  text-align: left;
  transition: color 0.5s;
}

#btn-emerger:hover { color: rgba(255,255,255,0.5); }

/* TRANSICIÓN HUNDIRSE */
#velo-transicion {
  position: fixed;
  inset: 0;
  background: var(--bg);
  z-index: 200;
  pointer-events: none;
  opacity: 0;
  transition: opacity 1s ease;
}

#velo-transicion.activo { opacity: 1; }

@keyframes aparecer {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

/* LEYENDA */
#leyenda {
  position: fixed;
  bottom: 1.5rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 2rem;
  z-index: 30;
  opacity: 0.4;
  pointer-events: none;
}

.leyenda-item {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  text-transform: lowercase;
}

.leyenda-punto {
  width: 5px;
  height: 5px;
  border-radius: 50%;
}

/* INSTRUCCION */
#instruccion {
  position: fixed;
  bottom: 4rem;
  left: 50%;
  transform: translateX(-50%);
  font-size: 0.6rem;
  letter-spacing: 0.35em;
  color: rgba(255,255,255,0.15);
  text-transform: lowercase;
  z-index: 30;
  pointer-events: none;
  white-space: nowrap;
}
</style>
</head>
<body>

<!-- VELO DE TRANSICIÓN -->
<div id="velo-transicion"></div>

<!-- SUPERFICIE -->
<div id="superficie">
  <nav id="nav-superficie">
    <a href="#contexto">proyecto</a>
    <a href="#archivo">archivo</a>
  </nav>
  <h1 id="titulo-nun">NùN</h1>
  <p id="subtitulo">memoria oceánica</p>
  <button id="hundirse-btn" onclick="hundirse()">∿ hundirse</button>
</div>

<!-- CAMPO PROFUNDO -->
<div id="campo">
  <canvas id="canvas-campo"></canvas>
  <div id="instruccion">toca una palabra</div>
  <div id="leyenda">
    <div class="leyenda-item">
      <div class="leyenda-punto" style="background:var(--desastre)"></div>
      <span>desastre</span>
    </div>
    <div class="leyenda-item">
      <div class="leyenda-punto" style="background:var(--mitologia)"></div>
      <span>mitología</span>
    </div>
    <div class="leyenda-item">
      <div class="leyenda-punto" style="background:var(--geopolitica)"></div>
      <span>geopolítica</span>
    </div>
    <div class="leyenda-item">
      <div class="leyenda-punto" style="background:var(--biologia)"></div>
      <span>biología</span>
    </div>
    <div class="leyenda-item">
      <div class="leyenda-punto" style="background:var(--antropoceno)"></div>
      <span>antropoceno</span>
    </div>
  </div>
</div>

<!-- PANEL DE NODO -->
<div id="panel-nodo">
  <div id="contenido-principal">
    <span id="nombre-nodo"></span>
    <img id="img-nodo" src="" alt="">
    <p id="texto-nodo"></p>
  </div>
  <div id="franja-lateral">
    <p id="label-conexiones">desde aquí</p>
    <div id="lista-conexiones"></div>
    <button id="btn-emerger" onclick="emerger()">∿ emerger</button>
  </div>
</div>

<script>
// ── CONFIGURACIÓN SUPABASE ──────────────────────────────────────────
const SUPABASE_URL = 'https://uwduhddojpodzyvipbrq.supabase.co'
const SUPABASE_ANON_KEY = 'sb_publishable_V38s6emQE9jMQ54WhSIlJw_7WzJhGFY'
const { createClient } = supabase
const db = createClient(SUPABASE_URL, SUPABASE_ANON_KEY)

// ── ESTADO ──────────────────────────────────────────────────────────
let nodos = []
let conexiones = []
let nodosCanvas = []
let nodoActivo = null
let historial = []
let animFrame = null
let t = 0
let dragNode = null, dragOx = 0, dragOy = 0

const COLORES = {
  desastre:   '#378ADD',
  mitologia:  '#7F77DD',
  geopolitica:'#D85A30',
  biologia:   '#1D9E75',
  antropoceno:'#BA7517'
}

const C = document.getElementById('canvas-campo')
const ctx = C.getContext('2d')

// ── CARGA DATOS ─────────────────────────────────────────────────────
async function cargarDatos() {
  const [{ data: n }, { data: c }] = await Promise.all([
    db.from('nodos').select('*').eq('activo', true),
    db.from('conexiones').select('*')
  ])
  nodos = n || []
  conexiones = c || []
  inicializarCanvas()
}

// ── INICIALIZAR CANVAS ──────────────────────────────────────────────
function inicializarCanvas() {
  redimensionar()
  nodosCanvas = nodos.map((n, i) => {
    const angulo = (i / nodos.length) * Math.PI * 2
    const radio = 0.25 + Math.random() * 0.2
    return {
      ...n,
      x: C.width / 2 + Math.cos(angulo) * C.width * radio,
      y: C.height / 2 + Math.sin(angulo) * C.height * radio * 0.7,
      ox: 0, oy: 0,
      vx: 0, vy: 0,
      fase: Math.random() * Math.PI * 2,
      velocidad: 0.3 + Math.random() * 0.4,
      amplitud: 10 + Math.random() * 18,
      fs: 13 + Math.random() * 4
    }
  })
  nodosCanvas.forEach(n => { n.ox = n.x; n.oy = n.y })
  dibujar()
}

function redimensionar() {
  C.width = window.innerWidth * devicePixelRatio
  C.height = window.innerHeight * devicePixelRatio
  C.style.width = window.innerWidth + 'px'
  C.style.height = window.innerHeight + 'px'
}

// ── DIBUJO ──────────────────────────────────────────────────────────
function dibujar() {
  t += 0.007
  ctx.clearRect(0, 0, C.width, C.height)

  // Fondo sutil
  const grad = ctx.createRadialGradient(C.width/2, C.height/2, 0, C.width/2, C.height/2, C.width * 0.6)
  grad.addColorStop(0, 'rgba(15,25,60,0.12)')
  grad.addColorStop(1, 'rgba(0,0,0,0)')
  ctx.fillStyle = grad
  ctx.fillRect(0, 0, C.width, C.height)

  // Mover nodos
  nodosCanvas.forEach(n => {
    if (n === dragNode) return
    n.x = n.ox + Math.sin(t * n.velocidad + n.fase) * n.amplitud * devicePixelRatio
    n.y = n.oy + Math.cos(t * n.velocidad * 0.7 + n.fase * 1.3) * n.amplitud * 0.6 * devicePixelRatio
  })

  // Conexiones del nodo activo
  if (nodoActivo) {
    const conns = obtenerConexiones(nodoActivo.id)
    conns.forEach(({ nodo: otro, peso }) => {
      if (!otro) return
      const lg = ctx.createLinearGradient(nodoActivo.x, nodoActivo.y, otro.x, otro.y)
      const c1 = hexRgba(COLORES[nodoActivo.eje], 0.6)
      const c2 = hexRgba(COLORES[otro.eje], 0.3)
      lg.addColorStop(0, c1)
      lg.addColorStop(1, c2)
      const mx = (nodoActivo.x + otro.x) / 2 + (otro.y - nodoActivo.y) * 0.12
      const my = (nodoActivo.y + otro.y) / 2 - (otro.x - nodoActivo.x) * 0.12
      ctx.beginPath()
      ctx.moveTo(nodoActivo.x, nodoActivo.y)
      ctx.quadraticCurveTo(mx, my, otro.x, otro.y)
      ctx.strokeStyle = lg
      ctx.lineWidth = (peso / 10) * 1.5 * devicePixelRatio
      ctx.setLineDash([4 * devicePixelRatio, 5 * devicePixelRatio])
      ctx.stroke()
      ctx.setLineDash([])
    })
  }

  // Palabras
  nodosCanvas.forEach(n => {
    const esActivo = n === nodoActivo
    const esConectado = nodoActivo && obtenerConexiones(nodoActivo.id).some(c => c.nodo === n)
    const esDim = nodoActivo && !esActivo && !esConectado

    const fs = n.fs * devicePixelRatio
    ctx.font = `${esActivo ? 400 : 300} ${fs}px Georgia, serif`
    const w = ctx.measureText(n.nombre).width

    // Halo activo
    if (esActivo) {
      ctx.beginPath()
      ctx.ellipse(n.x, n.y, w / 2 + 20 * devicePixelRatio, fs / 2 + 12 * devicePixelRatio, 0, 0, Math.PI * 2)
      ctx.fillStyle = hexRgba(COLORES[n.eje], 0.06)
      ctx.fill()
    }

    const alpha = esDim ? 0.08 : esConectado ? 0.9 : nodoActivo ? 0.35 : 0.65
    ctx.fillStyle = hexRgba(COLORES[n.eje], alpha)
    ctx.textAlign = 'center'
    ctx.textBaseline = 'middle'
    ctx.fillText(n.nombre, n.x, n.y)

    if (esActivo || esConectado) {
      ctx.beginPath()
      ctx.moveTo(n.x - w / 2, n.y + fs / 2 + 2 * devicePixelRatio)
      ctx.lineTo(n.x + w / 2, n.y + fs / 2 + 2 * devicePixelRatio)
      ctx.strokeStyle = hexRgba(COLORES[n.eje], esActivo ? 0.7 : 0.3)
      ctx.lineWidth = (esActivo ? 1 : 0.5) * devicePixelRatio
      ctx.stroke()
    }
  })

  animFrame = requestAnimationFrame(dibujar)
}

// ── CONEXIONES ──────────────────────────────────────────────────────
function obtenerConexiones(nodoId) {
  const ids = conexiones
    .filter(c => c.nodo_origen === nodoId || (c.bidireccional && c.nodo_destino === nodoId))
    .map(c => ({
      id: c.nodo_origen === nodoId ? c.nodo_destino : c.nodo_origen,
      peso: c.peso,
      tipo: c.tipo_relacion
    }))

  // Aplicar peso dinámico por historial
  return ids.map(({ id, peso, tipo }) => {
    const bonus = historial.filter(h => h === id).length * 1.5
    return {
      nodo: nodosCanvas.find(n => n.id === id),
      peso: Math.min(10, peso + bonus),
      tipo
    }
  }).filter(c => c.nodo).sort((a, b) => b.peso - a.peso)
}

// ── ACTIVAR NODO ────────────────────────────────────────────────────
async function activarNodo(nodo) {
  nodoActivo = nodo
  historial.push(nodo.id)

  // Cargar fragmento según historial
  let query = db.from('fragmentos')
    .select('*')
    .eq('nodo_id', nodo.id)
    .order('orden')

  // Si hay historial, intentar fragmento contextual
  if (historial.length > 1) {
    const prevId = historial[historial.length - 2]
    const { data: contextual } = await db.from('fragmentos')
      .select('*')
      .eq('nodo_id', nodo.id)
      .eq('contexto_previo', prevId)
      .limit(1)
    if (contextual && contextual.length > 0) {
      mostrarNodo(nodo, contextual[0])
      return
    }
  }

  const { data: fragmentos } = await query.limit(1)
  mostrarNodo(nodo, fragmentos?.[0] || null)
}

function mostrarNodo(nodo, fragmento) {
  document.getElementById('nombre-nodo').textContent = nodo.nombre
  document.getElementById('texto-nodo').textContent = nodo.texto_principal || ''

  const img = document.getElementById('img-nodo')
  img.classList.remove('cargado')

  if (fragmento?.tipo === 'imagen' && fragmento?.url) {
    img.src = fragmento.url
    img.onload = () => img.classList.add('cargado')
    img.style.display = 'block'
  } else {
    img.style.display = 'none'
  }

  // Conexiones en la franja lateral
  const conns = obtenerConexiones(nodo.id).slice(0, 8)
  const lista = document.getElementById('lista-conexiones')
  lista.innerHTML = ''

  conns.forEach(({ nodo: otro, peso, tipo }) => {
    if (!otro) return
    const color = COLORES[otro.eje]
    const div = document.createElement('div')
    div.className = 'conexion-item'
    div.style.color = color
    div.innerHTML = `
      <div class="conexion-nombre">${otro.nombre}</div>
      <div class="conexion-tipo">${tipo || ''}</div>
      <div class="conexion-barra" style="width:${peso * 10}%"></div>
    `
    div.onclick = () => transicionNodo(otro)
    lista.appendChild(div)
  })

  document.getElementById('panel-nodo').classList.add('visible')
}

async function transicionNodo(nodo) {
  const velo = document.getElementById('velo-transicion')
  velo.classList.add('activo')
  await esperar(600)
  await activarNodo(nodo)
  velo.classList.remove('activo')
}

// ── NAVEGACIÓN ──────────────────────────────────────────────────────
function hundirse() {
  const velo = document.getElementById('velo-transicion')
  velo.classList.add('activo')
  setTimeout(() => {
    document.getElementById('superficie').classList.add('oculto')
    document.getElementById('campo').classList.add('visible')
    velo.classList.remove('activo')
  }, 800)
}

function emerger() {
  const velo = document.getElementById('velo-transicion')
  velo.classList.add('activo')
  setTimeout(() => {
    document.getElementById('panel-nodo').classList.remove('visible')
    nodoActivo = null
    velo.classList.remove('activo')
  }, 600)
}

// ── EVENTOS CANVAS ──────────────────────────────────────────────────
function buscarNodo(px, py) {
  return nodosCanvas.slice().reverse().find(n => {
    ctx.font = `300 ${n.fs * devicePixelRatio}px Georgia, serif`
    const w = ctx.measureText(n.nombre).width
    const h = n.fs * devicePixelRatio
    return px >= n.x - w/2 - 10 && px <= n.x + w/2 + 10 &&
           py >= n.y - h/2 - 8 && py <= n.y + h/2 + 8
  })
}

function coordsCanvas(e) {
  const r = C.getBoundingClientRect()
  const touch = e.touches?.[0] || e
  return [
    (touch.clientX - r.left) * devicePixelRatio,
    (touch.clientY - r.top) * devicePixelRatio
  ]
}

C.addEventListener('click', e => {
  const [px, py] = coordsCanvas(e)
  const n = buscarNodo(px, py)
  if (n) activarNodo(n)
})

C.addEventListener('mousedown', e => {
  const [px, py] = coordsCanvas(e)
  const n = buscarNodo(px, py)
  if (n) { dragNode = n; dragOx = px - n.ox * devicePixelRatio; dragOy = py - n.oy * devicePixelRatio }
})

C.addEventListener('mousemove', e => {
  const [px, py] = coordsCanvas(e)
  if (dragNode) {
    dragNode.ox = (px - dragOx) / devicePixelRatio
    dragNode.oy = (py - dragOy) / devicePixelRatio
  }
  C.style.cursor = buscarNodo(px, py) ? 'pointer' : 'default'
})

C.addEventListener('mouseup', () => { dragNode = null })
C.addEventListener('touchstart', e => {
  const [px, py] = coordsCanvas(e)
  const n = buscarNodo(px, py)
  if (n) activarNodo(n)
}, { passive: true })

window.addEventListener('resize', () => {
  redimensionar()
  nodosCanvas.forEach(n => {
    n.ox = n.x = n.ox / C.width * window.innerWidth * devicePixelRatio
    n.oy = n.y = n.oy / C.height * window.innerHeight * devicePixelRatio
  })
})

// ── UTILS ────────────────────────────────────────────────────────────
function hexRgba(hex, a) {
  const r = parseInt(hex.slice(1,3), 16)
  const g = parseInt(hex.slice(3,5), 16)
  const b = parseInt(hex.slice(5,7), 16)
  return `rgba(${r},${g},${b},${a})`
}

function esperar(ms) { return new Promise(r => setTimeout(r, ms)) }

// ── INICIO ───────────────────────────────────────────────────────────
cargarDatos()
</script>
</body>
</html>
